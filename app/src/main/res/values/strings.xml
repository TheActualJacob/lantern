    <!-- Scanning UX: coaching, coverage guide, and correctness guardrails. -->
    <string name="coach_title">How to scan an object</string>
    <string name="coach_subtitle">A few habits make the 3D scan clean.</string>
    <string name="coach_rule_surface_title">Place it on a flat surface</string>
    <string name="coach_rule_surface_desc">Don\'t hold or rotate the object — moving objects break the scan.</string>
    <string name="coach_rule_orbit_title">Move the phone slowly around it</string>
    <string name="coach_rule_orbit_desc">Steady, gentle motion captures clean depth.</string>
    <string name="coach_rule_no_spin_title">Orbit around it — don\'t spin in place</string>
    <string name="coach_rule_no_spin_desc">Turning without moving gives no depth to work with.</string>
    <string name="coach_rule_distance_title">Keep it centered, about 20–60 cm away</string>
    <string name="coach_rule_distance_desc">Let the object fill the frame, not too close.</string>
    <string name="coach_rule_sides_title">Cover all sides — top, sides, and angles</string>
    <string name="coach_rule_sides_desc">Unseen faces become holes in the model.</string>
    <string name="coach_rule_light_title">Use good, even lighting; avoid glare</string>
    <string name="coach_rule_light_desc">Bright, soft light reads best.</string>
    <string name="coach_rule_hands_title">Keep hands out of frame</string>
    <string name="coach_rule_hands_desc">Fingers in view may end up in the scan — table placement keeps them out.</string>
    <string name="coach_rule_bottom_title">The resting face won\'t be scanned</string>
    <string name="coach_rule_bottom_desc">Put the least-important side down — the bottom is filled in automatically during cleanup.</string>
    <string name="coach_dismiss">Got it</string>
    <string name="coach_help_cd">Scanning tips</string>

